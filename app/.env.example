# Supabase - récupérer depuis Settings > API dans le dashboard Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=eyJhbGci...        # anon/public key (exposée côté client)
SUPABASE_SERVICE_KEY=eyJhbGci... # service_role key (serveur uniquement, ne jamais exposer)

# Secret d'authentification pour le Raspberry Pi Pico (NFC)
NFC_SECRET=un-secret-aleatoire-long-et-sur
